[engine1]
path="zig-out/bin/engine";
name="vanilla";
"setoption name useHash value false";
"setoption name searchType value zwsi";
"setoption name useQuiescence value true";

[engine2]
path="zig-out/bin/engine";
name="LMR";
"setoption name useHash value false";
"setoption name searchType value zwsi";
"setoption name useQuiescence value true";
"setoption name useLMR value true";

[match]
nMatch=4;
playerSwitch=true;
debugMode=false;
useOpeningBook=false;
openingBookPath="opening/8moves_v3.pgn";
timeFormat=(10000, 0);
logsLocation="out/logs/evaluate";
saveLogs=false;
printToScreen=false;

