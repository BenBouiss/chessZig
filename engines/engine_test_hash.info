[engine1]
path="zig-out/bin/engine";
name="no hash";
"setoption name UCI_elo value 3000";
"setoption name fixedDepth value false";
"setoption name useHash value false";
"setoption name useNullPruning value true";
"setoption name useQuiescence value true";

[engine2]
path="zig-out/bin/engine";
name="hash";
"setoption name UCI_elo value 3000";
"setoption name fixedDepth value false";
"setoption name useHash value true";
"setoption name hash value 1000";
"setoption name useNullPruning value true";
"setoption name useQuiescence value true";

[match]
nMatch=6;
playerSwitch=true;
debugMode=false;
useOpeningBook=true;
openingBookPath="opening/8moves_v3.pgn";
timeFormat=(60000, 100);

logsLocation="logs/ben/ben";
//saveLogs=true;

